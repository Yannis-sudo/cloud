# Database Configuration
DATABASE_URL=mongodb://localhost:27017
DATABASE_NAME=cloud

# Security Configuration
SECRET_KEY=your-super-secret-key-change-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:5173,http://10.168.6.136:5173,http://localhost:3000,http://127.0.0.1:5173

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Rate Limiting Configuration
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# Email Configuration
IMAP_TIMEOUT=30
SMTP_TIMEOUT=30

# Logging Configuration
LOG_LEVEL=INFO

# Development Configuration
DEBUG=false